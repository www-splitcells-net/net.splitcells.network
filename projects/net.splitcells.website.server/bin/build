#!/usr/bin/env sh
# SPDX-License-Identifier: EPL-2.0 OR GPL-2.0-or-later
# SPDX-FileCopyrightText: Contributors To The `net.splitcells.*` Projects
set -e
chmod +x ./bin/*
mvn verify
test -f ./target/keystore.p12 || keytool -genkey \
	-noprompt \
	-alias 'cert' \
	-keypass 'password' \
	-keyalg 'RSA' \
	-validity 365 \
	-dname 'CN=localhost' \
	-keysize 4096 \
	-keystore ./target/keystore.p12 \
	-storepass 'password' \
	-storetype  'PKCS12'